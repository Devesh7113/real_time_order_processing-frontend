# Backend base URL (no trailing slash). Copy to `.env` and adjust if needed.
# If the browser blocks requests, add this app’s origin to `app.cors.allowed-origins` in the API’s application.properties (e.g. http://localhost:5173).
VITE_API_BASE_URL=http://localhost:8080

# Optional: where relative product image paths resolve (defaults to VITE_API_BASE_URL).
# Use if images are served from another host. Full https URLs in the DB need no extra config.
# VITE_IMAGE_CDN_BASE=http://localhost:8080
